{
  "kind": "collectionType",
  "collectionName": "requests",
  "info": {
    "singularName": "request",
    "pluralName": "requests",
    "displayName": "Request"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "typeNeed": {
      "type": "enumeration",
      "enum": [
        "Food",
        "Medical",
        "Rescue",
        "Shelter",
        "Water",
        "Other"
      ]
    },
    "urgencyType": {
      "type": "enumeration",
      "enum": [
        "High",
        "Medium",
        "Low"
      ]
    },
    "address": {
      "type": "string",
      "required": true
    },
    "peopleAffected": {
      "type": "integer",
      "required": true
    },
    "description": {
      "type": "string",
      "required": true
    },
    "stats": {
      "type": "enumeration",
      "default": "Pending",
      "enum": [
        "Pending",
        "In Progress",
        "Resolved"
      ]
    },
    "requester": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::account.account",
      "inversedBy": "requests"
    }
  }
}
